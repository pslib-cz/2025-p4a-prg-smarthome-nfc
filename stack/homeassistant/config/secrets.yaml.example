# Copy this file to secrets.yaml and fill in your values.
# The real secrets.yaml is gitignored so your credentials never leak.

# --- MQTT credentials (must match stack/mosquitto/config/passwd) ---
# Generated by ./smartlend.sh install if both files are fresh.
mqtt_user: smartlend
mqtt_password: "CHANGE_ME_MQTT_PASSWORD"

# --- NFC tag UIDs that map to specific items (optional legacy — the UI flow
#     doesn't need these; they were used by the old tag-platform automations
#     that are now removed). Kept here as documentation. ---
tag_uid_usb_c_cable: "00-00-00-00"
tag_uid_adapter: "00-00-00-00"
tag_uid_meter: "00-00-00-00"
tag_uid_user_card: "00-00-00-00"
