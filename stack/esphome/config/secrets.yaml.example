# Copy this file to secrets.yaml and fill in your values.
# Then flash the ESP32 via:  ./smartlend.sh flash
#
# The real secrets.yaml is gitignored so your credentials never leak.

# --- Wi-Fi the ESP32 will join ---
wifi_ssid: "YOUR_WIFI_NAME"
wifi_password: "YOUR_WIFI_PASSWORD"

# --- Fallback AP (when Wi-Fi is unreachable the ESP hosts this for recovery) ---
# Any 8+ char password. Generated automatically by ./smartlend.sh install if empty.
smartlend_fallback_password: "CHANGE_ME_FALLBACK_AP_PASSWORD"

# --- Native API encryption (32 bytes base64). Generated by ./smartlend.sh install. ---
# Must match the value stored in Home Assistant's ESPHome integration settings.
smartlend_api_key: "GENERATED_BASE64_32_BYTE_KEY"

# --- OTA firmware password (prevents unauthorized over-the-air flashing) ---
smartlend_ota_password: "CHANGE_ME_OTA_PASSWORD"
