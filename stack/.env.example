# Copy this file to .env and fill in HA_TOKEN after running the stack once.
# The real .env is gitignored so your token never leaks.

TZ=Europe/Prague

# --- Home Assistant URL used by the Next.js UI ---
# https:// is required (HA runs with TLS enabled).
HA_URL=https://localhost:8123

# --- Long-lived access token ---
# Create via: HA → user profile (bottom left) → Security → Long-lived access tokens.
# Or run:  ./smartlend.sh install    — the script will print instructions.
HA_TOKEN=PASTE_YOUR_HA_LONG_LIVED_TOKEN_HERE
